// .hc:276
pub fun hc_with_transaction(d : db, f)
  match hc_sqlite_begin(d)
    Left(e) ->
      Left(e)
    Right(_) ->
      val r = f(d)
      match r
        Left(e) ->
          val _ = hc_sqlite_rollback(d)
          Left(e)
        Right(v) ->
          match hc_sqlite_commit(d)
            Left(e) ->
              val _ = hc_sqlite_rollback(d)
              Left(e)
            Right(_) ->
              Right(v)

